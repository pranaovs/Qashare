{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "rebaseWhen": "behind-base-branch",
  "internalChecksFilter": "none",
  "prHourlyLimit": 5,
  "labels": [
    "dependencies",
    "renovate"
  ],
  "pinDigests": true,
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "description": "Automerge minor/patch updates after stability delay",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin"
      ],
      "automerge": true,
      "automergeStrategy": "fast-forward",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Automerge docker digest updates immediately",
      "matchUpdateTypes": [
        "digest"
      ],
      "automerge": true,
      "automergeStrategy": "fast-forward"
    },
    {
      "description": "Don't pin digests for docker-compose.yml",
      "matchFileNames": [
        "server/docker-compose.yml"
      ],
      "pinDigests": false
    },
    {
      "matchFileNames": [
        "client/**"
      ],
      "groupName": "flutter dependencies",
      "commitMessagePrefix": "chore(client):",
      "labels": [
        "client"
      ]
    },
    {
      "matchFileNames": [
        "server/**"
      ],
      "groupName": "go dependencies",
      "commitMessagePrefix": "chore(server):",
      "labels": [
        "server"
      ]
    }
  ]
}
